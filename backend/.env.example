# local / development / production
APP_ENV=local

# admin account (single-admin mode)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123456

# local: can keep sqlite fallback
# production(vercel): MUST set to external database connection string
DATABASE_URL=sqlite:///./reconciliation.db

# Supabase Auth (邮箱+密码登录)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# 仅后端使用：管理员重置密码等管理接口（严禁放到前端）
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
